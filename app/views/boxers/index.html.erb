<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 border-b pb-4">
  <div>
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">🥊 Boxing Database</h1>
    <p class="text-sm text-gray-500 mt-1">世界のボクサー情報を検索・管理</p>
  </div>
  <%= link_to '新規登録', new_boxer_path, class: "mt-4 md:mt-0 inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 transition" %>
</div>

<div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-8">
  <%= form_with(url: boxers_path, method: :get, local: true, class: "flex gap-2") do |form| %>
    <%= form.text_field :search, value: params[:search], placeholder: "ボクサー名や階級を入力（例: 井上尚弥, バンタム級）...", 
        class: "block w-full rounded-md border-gray-300 shadow-sm px-4 py-2 border focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    <%= form.submit "検索", class: "inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-gray-800 hover:bg-gray-900 cursor-pointer transition" %>
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <% @boxers.each do |boxer| %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:shadow-md transition">
      <div>
        <div class="flex justify-between items-start">
          <h2 class="text-xl font-bold text-gray-800"><%= boxer.name %></h2>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
            <%= boxer.weight_class %>
          </span>
        </div>
        
        <div class="mt-4 space-y-2 text-sm text-gray-600">
          <p><span class="font-semibold text-gray-400">戦績:</span> <%= boxer.record %></p>
          <p><span class="font-semibold text-gray-400">スタイル:</span> <%= boxer.style %></p>
        </div>
      </div>

      <div class="mt-6 flex justify-end space-x-3 border-t pt-4 border-gray-50 text-xs">
        <%= link_to '詳細を見る', boxer, class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
        <%= link_to '編集', edit_boxer_path(boxer), class: "text-gray-500 hover:text-gray-700" %>
      </div>
    </div>
  <% end %>
</div>