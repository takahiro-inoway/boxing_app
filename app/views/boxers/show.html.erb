<div class="mb-6">
  <%= link_to '← 一覧に戻る', boxers_path, class: "text-sm text-indigo-600 hover:text-indigo-800" %>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
  <div class="bg-gray-950 px-6 py-8 text-white">
    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-indigo-500 mb-2">
      <%= @boxer.weight_class %>
    </span>
    <h1 class="text-3xl font-black"><%= @boxer.name %></h1>
  </div>

  <div class="p-6 space-y-6">
    <div class="grid grid-cols-2 gap-4 border-b pb-6">
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wider">戦績</p>
        <p class="text-lg font-bold text-gray-800 mt-1"><%= @boxer.record %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wider">スタイル</p>
        <p class="text-lg font-bold text-gray-800 mt-1"><%= @boxer.style %></p>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-100 rounded-xl p-5">
      <h3 class="text-sm font-bold text-blue-800 flex items-center gap-1">
        🌐 Web自動取得の概要 (Wikipediaより)
      </h3>
      <p class="text-sm text-blue-950 mt-2 leading-relaxed">
        <%= @boxer.fetch_wikipedia_summary %>
      </p>
    </div>
  </div>

  <div class="bg-gray-50 px-6 py-4 flex justify-between border-t border-gray-100">
    <%= link_to 'この情報を編集', edit_boxer_path(@boxer), class: "text-sm text-gray-600 hover:text-gray-900" %>
    <%= button_to '削除する', @boxer, method: :delete, data: { confirm: '本当に削除しますか？' }, class: "text-sm text-red-600 hover:text-red-800" %>
  </div>
</div>